# AWS deployment
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# S3 bucket for benchmark results (created externally)
BEFAAS_RESULTS_BUCKET=
BEFAAS_RESULTS_REGION=

# Edge / JWT auth
EDGE_PUBLIC_KEY=
EDGE_JWKS_MODE=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Docker Hub
DOCKERHUB_USER=

# OpenFaaS
OPENFAAS_GATEWAY=
OPENFAAS_TOKEN=
OPENFAAS_USER=

# OpenWhisk
OPENWHISK_EXTERNAL=

# tinyFaaS
TINYFAAS_ADDRESS=
TINYFAAS_FPORT=
TINYFAAS_MPORT=

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PROJECT=
GOOGLE_REGION=

# Terraform
TF_CLI_CONFIG_FILE=

# Postgres (analysis / import)
PGHOST=localhost
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=
PGGSSENCMODE=disable

# DB import tuning
DB_IMPORT_OPTIMIZED=true
DB_IMPORT_USE_COPY=true
DB_IMPORT_DROP_INDEXES=true
DB_IMPORT_COPY_BATCH_SIZE=100000
DB_IMPORT_BATCH_SIZE=50000
DB_IMPORT_COMMIT_EVERY=500000
DB_IMPORT_ENRICH_POST=true
DB_IMPORT_FLUSH_DELAY=0.1